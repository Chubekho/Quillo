# ──────────────────────────────────────────────────────────────
# Quillo Backend — Environment Variables
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env vào git
# ──────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ── Database (Prisma) ─────────────────────────────────────────
# Local dev: dùng Docker Compose
DATABASE_URL="postgresql://quillo:quillo_secret@localhost:5432/quillo_dev?schema=public"

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis (cache + rate limit) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AWS Core ─────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Khi dev local, trỏ về LocalStack
AWS_ENDPOINT_URL=http://localhost:4566

# ── AWS SQS ──────────────────────────────────────────────────
SQS_GENERATION_QUEUE_URL=http://sqs.ap-southeast-1.localhost.localstack.cloud:4566/000000000000/quillo-generation-queue
SQS_DLQ_URL=http://sqs.ap-southeast-1.localhost.localstack.cloud:4566/000000000000/quillo-generation-dlq

# ── AWS S3 ───────────────────────────────────────────────────
S3_EXPORTS_BUCKET=quillo-exports
S3_ASSETS_BUCKET=quillo-assets

# ── Amazon Bedrock ───────────────────────────────────────────
# Lưu ý: Bedrock không có LocalStack emulation, cần AWS thật để test AI
# Model IDs: kiểm tra lại trong Bedrock console vì AWS update thường xuyên
BEDROCK_GENERATE_MODEL=us.anthropic.claude-sonnet-4-5
BEDROCK_EDIT_MODEL=us.anthropic.claude-haiku-4-5

# ── Token & Quota limits ─────────────────────────────────────
DEFAULT_MONTHLY_TOKEN_QUOTA=500000
MAX_TOKENS_PER_GENERATION=4096

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
