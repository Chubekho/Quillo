# ══════════════════════════════════════════════════════════════
# Quillo Backend — Production Environment Template
# ══════════════════════════════════════════════════════════════
# Copy to .env.production before deploying.
# NEVER commit real secrets to git.
# Secrets (DB password, JWT secret, API keys) are injected via
# AWS Secrets Manager at runtime when USE_SECRETS_MANAGER=true.
# ══════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

# ── AWS Secrets Manager ───────────────────────────────────────
# Set to true in production; secrets.ts will fetch from SM
# and inject into process.env at startup.
USE_SECRETS_MANAGER=true
APP_SECRETS_ID=quillo/app-secrets
AWS_REGION=ap-southeast-1
# NOTE: AWS_ENDPOINT_URL must NOT be set in production.
# Production uses real AWS endpoints (no LocalStack).
# AWS credentials are supplied via EC2 instance role / Lambda execution role.

# ── Database (injected via Secrets Manager) ───────────────────
# DATABASE_URL is set by secrets.ts at runtime from SM secret.
# Placeholder shown for documentation only:
# DATABASE_URL=postgresql://<user>:<password>@<rds-endpoint>:5432/quillo_prod

# ── Redis / ElastiCache ───────────────────────────────────────
# REDIS_URL is injected via Secrets Manager.
# Placeholder:
# REDIS_URL=rediss://<elasticache-cluster-endpoint>:6379

# ── JWT (injected via Secrets Manager) ───────────────────────
# JWT_SECRET is injected via Secrets Manager.
# JWT_REFRESH_SECRET is injected via Secrets Manager.
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── AI Provider ───────────────────────────────────────────────
AI_PROVIDER=gemini
# For Bedrock (alternative): set AI_PROVIDER=bedrock and configure
# BEDROCK_REGION + model IDs (injected via SM if needed).

# ── SQS ──────────────────────────────────────────────────────
# Replace <account-id> with your real AWS account ID.
SQS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/<account-id>/quillo-generation-queue

# ── S3 ────────────────────────────────────────────────────────
S3_BUCKET=quillo-exports-prod
S3_REGION=ap-southeast-1

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Replace with your actual production domain(s).
ALLOWED_ORIGINS=https://<your-prod-domain.com>

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
# CloudWatch log group (used by winston-cloudwatch)
CLOUDWATCH_LOG_GROUP=/quillo/api/production
CLOUDWATCH_LOG_STREAM=api-server
