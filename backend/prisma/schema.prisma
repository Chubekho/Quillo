// Quillo — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ContentType {
  BLOG_POST
  SOCIAL_MEDIA
  AD_COPY
  EMAIL
}

enum ContentStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ExportFormat {
  PDF
  DOCX
  HTML
}

enum ContentVersionSource {
  AI_GENERATE
  AI_REWRITE
  AI_EXPAND
  AI_SHORTEN
  HUMAN_EDIT
}

enum AssetType {
  LOGO
  BRAND_IMAGE
  AVATAR
  OTHER
}

// ──────────────────────────────────────────────────────────────
// ORGANIZATIONS  (root of multi-tenancy)
// ──────────────────────────────────────────────────────────────

model Organization {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique // dùng làm subdomain sau này
  plan    OrgPlan @default(FREE)
  logoUrl String?

  // Quota kiểm soát chi phí Bedrock
  monthlyTokenQuota  Int      @default(500000)
  currentMonthTokens Int      @default(0)
  quotaResetAt       DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  brandPersonas BrandPersona[]
  campaigns     Campaign[]
  contentPieces ContentPiece[]
  assets        Asset[]
  usageLogs     UsageLog[]

  @@map("organizations")
}

// ──────────────────────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String   @unique
  name           String
  passwordHash   String
  role           UserRole @default(MEMBER)
  avatarUrl      String?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]     @relation("CampaignCreator")
  refreshTokens RefreshToken[]

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────────────────────
// BRAND PERSONAS  (điểm khác biệt cốt lõi của Quillo)
// ──────────────────────────────────────────────────────────────

model BrandPersona {
  id             String @id @default(uuid())
  organizationId String
  name           String // "Formal B2B", "Casual Gen-Z", ...

  // Giọng điệu & phong cách
  tone  String // "professional", "playful", "empathetic"...
  voice String? // mô tả ngắn "Chúng tôi là người bạn đồng hành tin cậy..."

  // Đối tượng khách hàng
  targetAudience String
  ageRange       String? // "25-40"
  industry       String?

  // Ngôn ngữ & văn phong
  language       String @default("vi")
  formalityLevel Int    @default(3) // 1=rất casual, 5=rất formal

  // Keywords & cấm kỵ
  keywords   String[] // từ khóa muốn xuất hiện nhiều
  avoidWords String[] // từ / cụm từ không được dùng

  // Ví dụ mẫu để few-shot prompting
  exampleOutputs String[] // 1-3 đoạn content mẫu đúng giọng

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentPieces ContentPiece[]

  @@index([organizationId])
  @@map("brand_personas")
}

// ──────────────────────────────────────────────────────────────
// CAMPAIGNS
// ──────────────────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  createdById    String
  name           String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("CampaignCreator", fields: [createdById], references: [id])
  contentPieces ContentPiece[]

  @@index([organizationId])
  @@map("campaigns")
}

// ──────────────────────────────────────────────────────────────
// CONTENT PIECES  (một bài viết / post / email)
// ──────────────────────────────────────────────────────────────

model ContentPiece {
  id             String        @id @default(uuid())
  organizationId String
  campaignId     String?
  personaId      String?
  title          String
  type           ContentType
  brief          String // Marketing Brief — input từ user
  targetAudience String? // override persona nếu cần
  status         ContentStatus @default(DRAFT)

  // Metadata cho từng loại content
  // Blog: seoKeywords, wordCount target
  // Social: platform (fb/ig/linkedin/tiktok), hashtags
  // Ad: cta, landingUrl
  // Email: subject, preheader
  meta Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  persona      BrandPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  versions       ContentVersion[]
  generationJobs GenerationJob[]
  exports        Export[]
  usageLogs      UsageLog[]

  @@index([organizationId])
  @@index([campaignId])
  @@map("content_pieces")
}

// ──────────────────────────────────────────────────────────────
// CONTENT VERSIONS  (lịch sử mọi phiên bản chỉnh sửa)
// ──────────────────────────────────────────────────────────────

model ContentVersion {
  id        String               @id @default(uuid())
  contentId String
  versionNo Int // tăng dần, 1, 2, 3...
  body      String // nội dung thực tế
  source    ContentVersionSource
  isActive  Boolean              @default(true) // phiên bản hiện tại

  // Prompt đã dùng — debug & audit
  promptUsed String?

  // Token count của version này
  inputTokens  Int @default(0)
  outputTokens Int @default(0)

  createdAt DateTime @default(now())

  content ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, versionNo])
  @@index([contentId, isActive])
  @@map("content_versions")
}

// ──────────────────────────────────────────────────────────────
// GENERATION JOBS  (theo dõi trạng thái async)
// ──────────────────────────────────────────────────────────────

model GenerationJob {
  id           String    @id @default(uuid())
  contentId    String
  status       JobStatus @default(QUEUED)
  operation    String // "generate", "rewrite", "expand", "shorten"
  sqsMessageId String? // để idempotency check

  // Error handling
  errorMessage String?
  retryCount   Int     @default(0)

  // Timing
  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  content ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([status])
  @@map("generation_jobs")
}

// ──────────────────────────────────────────────────────────────
// EXPORTS
// ──────────────────────────────────────────────────────────────

model Export {
  id            String       @id @default(uuid())
  contentId     String
  format        ExportFormat
  s3Key         String // đường dẫn trong S3 bucket
  fileSizeBytes Int?
  downloadCount Int          @default(0)

  createdAt DateTime  @default(now())
  expiresAt DateTime? // presigned URL expiry

  content ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("exports")
}

// ──────────────────────────────────────────────────────────────
// ASSETS  (logo, brand images)
// ──────────────────────────────────────────────────────────────

model Asset {
  id             String    @id @default(uuid())
  organizationId String
  type           AssetType
  s3Key          String
  fileName       String
  mimeType       String
  fileSizeBytes  Int

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("assets")
}

// ──────────────────────────────────────────────────────────────
// USAGE LOGS  (token tracking — kiểm soát chi phí Bedrock)
// ──────────────────────────────────────────────────────────────

model UsageLog {
  id             String  @id @default(uuid())
  organizationId String
  contentId      String?
  model          String // tên model Bedrock thực tế
  operation      String // "generate" | "rewrite" | "expand" | "shorten"
  inputTokens    Int
  outputTokens   Int

  // Cost estimate (USD) — tính dựa theo pricing model
  estimatedCostUsd Decimal @db.Decimal(10, 6)

  createdAt DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  content      ContentPiece? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("usage_logs")
}
